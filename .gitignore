# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.ruff_cache/
.venv/
venv/
.mypy_cache/

# OS
.DS_Store
Thumbs.db

# Signing PRIVATE keys MUST NEVER be committed — no exceptions.
# Verification needs ONLY the PUBLIC key (the committed allowlist
# amber/keys/trusted_signers.txt + amber/keys/demo-signer.pub), so a fresh clone
# still verifies the golden packet GREEN with no secret. SEALING is an operator
# action that needs the secret: the demo private key lives at the gitignored
# path amber/keys/demo-signer.key (or env AMBER_SIGNING_KEY) and is regenerable.
*.key
*.pem
secrets/
*.private

# Bright Data credentials (Component 2) — secrets, NEVER committed.
# Loaded from the process env or this gitignored file by amber/capture/credentials.py.
.env
.env.*
!.env.example
# Credential files at the REPO ROOT only (leading slash) so the source module
# amber/capture/credentials.py is NOT ignored.
/credentials.json
/credentials.txt
/brightdata.json
/brightdata-creds.json
*.creds
