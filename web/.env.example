# Amber Component 3 (web demo) — environment template. Copy to web/.env.local
# (gitignored) and uncomment as needed. All are OPTIONAL — the demo runs from a
# fresh clone with no env set, rendering the committed fixture packet.

# Packet directory to render + verify. Absolute, or relative to code/.
# Swap in the real Bright Data DE/BE capture by pointing this at its dir.
# AMBER_PACKET_DIR=samples/live_packet

# Explicit Python interpreter that has the `amber` package installed.
# Leave unset to auto-detect the repo venv (code/.venv), then py/python3.
# AMBER_PYTHON=C:\yash\lablab\WEBDATA\code\.venv\Scripts\python.exe

# Trusted signer public key(s) the signature is pinned to (comma/space list).
# Leave unset to use the committed demo signer.
# AMBER_TRUSTED_PUBKEY=f2de2b5f14785372ced46288f3009448db17495312fe0492377fd14b036a5dc8
