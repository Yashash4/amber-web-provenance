ull}]},{\"__typename\":\"GraphqlProductFeature\",\"name\":\"Farbe (laut Hersteller)\",\"type\":null,\"unit\":null,\"value\":\"Weiß\",\"featureId\":\"PROD_FEAT_10812\",\"valuesAndUnits\":[{\"__typename\":\"GraphqlFeatureValue\",\"value\":\"Weiß\",\"unit\":null,\"id\":null}]},{\"__typename\":\"GraphqlProductFeature\",\"name\":\"Lieferumfang\",\"type\":null,\"unit\":null,\"value\":\"AirPods 4 mit Aktiver Geräuschunterdrückung, Ladecase (USB‑C) mit Lautsprecher, Dokumentation, (USB‑C Ladekabel separat erhältlich)\",\"featureId\":\"PROD_FEAT_11470\",\"valuesAndUnits\":[{\"__typename\":\"GraphqlFeatureValue\",\"value\":\"AirPods 4 mit Aktiver Geräuschunterdrückung, Ladecase (USB‑C) mit Lautsprecher, Dokumentation, (USB‑C Ladekabel separat erhältlich)\",\"unit\":null,\"id\":null}]},{\"__typename\":\"GraphqlProductFeature\",\"name\":\"Packmaße (BxHxT) (cm)\",\"type\":null,\"unit\":null,\"value\":\"85 mm / 85 mm / 35 mm\",\"featureId\":\"PROD_FEAT_15516\",\"valuesAndUnits\":[{\"__typename\":\"GraphqlFeatureValue\",\"value\":\"85 mm / 85 mm / 35 mm\",\"unit\":null,\"id\":null}]},{\"__typename\":\"GraphqlProductFeature\",\"name\":\"Schutzart\",\"type\":null,\"unit\":null,\"value\":\"IP54\",\"featureId\":\"PROD_FEAT_16309\",\"valuesAndUnits\":[{\"__typename\":\"GraphqlFeatureValue\",\"value\":\"IP54\",\"unit\":null,\"id\":\"54\"}]},{\"__typename\":\"GraphqlProductFeature\",\"name\":\"Variante\",\"type\":null,\"unit\":null,\"value\":\"Airpods 4 mit ANC\",\"featureId\":\"PROD_FEAT_16800\",\"valuesAndUnits\":[{\"__typename\":\"GraphqlFeatureValue\",\"value\":\"Airpods 4 mit ANC\",\"unit\":null,\"id\":null}]},{\"__typename\":\"GraphqlProductFeature\",\"name\":\"Hersteller Artikelnummer\",\"type\":null,\"unit\":null,\"value\":\"MXP93ZM/A\",\"featureId\":\"PROD_FEAT_00002\",\"valuesAndUnits\":[{\"__typename\":\"GraphqlFeatureValue\",\"value\":\"MXP93ZM/A\",\"unit\":null,\"id\":null}]}],\"featureGroupId\":\"FET_GRP_1461_0500\",\"featureGroupName\":\"Allgemeine Merkmale\"},{\"__typename\":\"GraphqlProductFeatureGroup\",\"features\":[{\"__typename\":\"GraphqlProductFeature\",\"name\":\"Modelljahr\",\"type\":null,\"unit\":null,\"value\":\"2024\",\"featureId\":\"PROD_FEAT_16617\",\"valuesAndUnits\":[{\"__typename\":\"GraphqlFeatureValue\",\"value\":\"2024\",\"unit\":null,\"id\":null}]}],\"featureGroupId\":\"FET_GRP_1461_1240\",\"featureGroupName\":\"Update Richtlinie\"},{\"__typename\":\"GraphqlProductFeatureGroup\",\"features\":[{\"__typename\":\"GraphqlProductFeature\",\"name\":\"Datenart, -form und -umfang\",\"type\":null,\"unit\":null,\"value\":\"Art: Während der Nutzung werden kontinuierlich technische Daten des vernetzten Apple Produkts erzeugt, z. B. Sensordaten und Betriebsstatusdaten (etwa Akkuzustand, Kopplungs‑ oder Netzwerkstatus) sowie ggf. Analysedaten wie Absturzprotokolle oder Leistungskennzahlen.\\nForm: Die von Apple bereitgestellten Daten werden in standardmäßigen, lesbaren digitalen Formaten bzw. strukturierten Dateien bereitgestellt, die nach App/Systemprozess und Zeitstempel geordnet sind.\\nUmfang / Dauer: Ein Großteil der Nutzungs‑ und Rohdaten wird unmittelbar oder innerhalb von ca. 24 Stunden gelöscht; einige Daten verbleiben nur für wenige Tage auf dem Gerät. Freiwillig freigegebene Analysedaten können auf Apple‑Servern bis zu 2 Jahre gespeichert und für Analysezwecke genutzt werden.\",\"featureId\":\"PROD_FEAT_94000\",\"valuesAndUnits\":[{\"__typename\":\"GraphqlFeatureValue\",\"value\":\"Art: Während der Nutzung werden kontinuierlich technische Daten des vernetzten Apple Produkts erzeugt, z. B. Sensordaten und Betriebsstatusdaten (etwa Akkuzustand, Kopplungs‑ oder Netzwerkstatus) sowie ggf. Analysedaten wie Absturzprotokolle oder Leistungskennzahlen.\\nForm: Die von Apple bereitgestellten Daten werden in standardmäßigen, lesbaren digitalen Formaten bzw. strukturierten Dateien bereitgestellt, die nach App/Systemprozess und Zeitstempel geordnet sind.\\nUmfang / Dauer: Ein Großteil der Nutzungs‑ und Rohdaten wird unmittelbar oder innerhalb von ca. 24 Stunden gelöscht; einige Daten verbleiben nur für wenige Tage auf dem Gerät. Freiwillig freigegebene Analysedaten können auf Apple‑Servern bis zu 2 Jahre gespeichert und für Analysezwecke genutzt werden.\",\"unit\":null,\"id\":null}]},{\"__typename\":\"GraphqlProductFeature\",\"name\":\"Echtzeit-Datengenerierung\",\"type\":null,\"unit\":null,\"value\":\"Ja\",\"featureId\":\"PROD_FEAT_94001\",\"valuesAndUnits\":[{\"__typename\":\"GraphqlFeatureValue\",\"value\":\"Ja\",\"unit\":null,\"id\":\"1\"}]},{\"__typename\":\"GraphqlProductFeature\",\"name\":\"Speicherung von Daten\",\"type\":null,\"unit\":null,\"value\":\"Ja\",\"featureId\":\"PROD_FEAT_94002\",\"valuesAndUnits\":[{\"__typename\":\"GraphqlFeatureValue\",\"value\":\"Ja\",\"unit\":null,\"id\":\"1\"}]},{\"__typename\":\"GraphqlProductFeature\",\"name\":\"Speicherdauer von Daten\",\"type\":null,\"unit\":null,\"value\":\"Ein Großteil der Nutzungs‑ und Rohdaten wird sofort oder innerhalb von ca. 24 Stunden gelöscht; einige Daten verbleiben nur wenige Tage auf dem Gerät. Freiwillig freigegebene Analysedaten können auf Apple‑Servern bis zu 2 Jahre gespeichert werden; weitere personenbezogene Daten nur solange, wie dies für die gewählten Dienste erforderlich ist.\",\"featureId\":\"PROD_FEAT_94003\",\"valuesAndUnits\":[{\"__typename\":\"GraphqlFeatureValue\",\"value\":\"Ein Großteil der Nutzungs‑ und Rohdaten wird sofort oder innerhalb von ca. 24 Stunden gelöscht; einige Daten verbleiben nur wenige Tage auf dem Gerät. Freiwillig freigegebene Analysedaten können auf Apple‑Servern bis zu 2 Jahre gespeichert werden; weitere personenbezogene Daten nur solange, wie dies für die gewählten Dienste erforderlich ist.\",\"unit\":null,\"id\":null}]},{\"__typename\":\"GraphqlProductFeature\",\"name\":\"Zugriffsmöglichkeit des Nutzers\",\"type\":null,\"unit\":null,\"value\":\"Zugriff auf personenbezogene Nutzungsdaten erfolgt über die Apple‑Seite ‚Daten und Datenschutz‘ (https://privacy.apple.com) nach Anmeldung mit dem Apple‑Account; dort können Daten ausgewählt, heruntergeladen und das Konto mit zugehörigen Daten gelöscht werden. Geräteanalysedaten können zusätzlich direkt über auf dem Gerät bereitgestellte Tools in strukturierten Dateien exportiert werden.\",\"featureId\":\"PROD_FEAT_94004\",\"valuesAndUnits\":[{\"__typename\":\"GraphqlFeatureValue\",\"value\":\"Zugriff auf personenbezogene Nutzungsdaten erfolgt über die Apple‑Seite ‚Daten und Datenschutz‘ (https://privacy.apple.com) nach Anmeldung mit dem Apple‑Account; dort können Daten ausgewählt, heruntergeladen und das Konto mit zugehörigen Daten gelöscht werden. Geräteanalysedaten können zusätzlich direkt über auf dem Gerät bereitgestellte Tools in strukturierten Dateien exportiert werden.\",\"unit\":null,\"id\":null}]},{\"__typename\":\"GraphqlProductFeature\",\"name\":\"Link zu Herstellerinformationen\",\"type\":null,\"unit\":null,\"value\":\"https://www.apple.com/legal/privacy/\",\"featureId\":\"PROD_FEAT_94006\",\"valuesAndUnits\":[{\"__typename\":\"GraphqlFeatureValue\",\"value\":\"https://www.apple.com/legal/privacy/\",\"unit\":null,\"id\":null}]}],\"featureGroupId\":\"FET_GRP_1461_9400\",\"featureGroupName\":\"Informationen nach EU Data Act\"}],\"accessoriesRelated\":[{\"__typename\":\"GraphqlRelatedProduct\",\"productId\":\"2694742\"},{\"__typename\":\"GraphqlRelatedProduct\",\"productId\":\"2731996\"},{\"__typename\":\"GraphqlRelatedProduct\",\"productId\":\"2732002\"},{\"__typename\":\"GraphqlRelatedProduct\",\"productId\":\"2732008\"},{\"__typename\":\"GraphqlRelatedProduct\",\"productId\":\"2771285\"},{\"__typename\":\"GraphqlRelatedProduct\",\"productId\":\"2833460\"},{\"__typename\":\"GraphqlRelatedProduct\",\"productId\":\"2841677\"},{\"__typename\":\"GraphqlRelatedProduct\",\"productId\":\"2897990\"},{\"__typename\":\"GraphqlRelatedProduct\",\"productId\":\"2898345\"},{\"__typename\":\"GraphqlRelatedProduct\",\"productId\":\"2898348\"},{\"__typename\":\"GraphqlRelatedProduct\",\"productId\":\