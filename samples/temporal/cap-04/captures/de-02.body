lche über Ausnahmeregelungen zugelassenen Substanzen für neue Produkte nicht mehr zu verwenden, sofern technisch möglich.","unit":null}]},"GraphqlProductFeature:PROD_FEAT_16042:AirPods (4th generation)":{"__typename":"GraphqlProductFeature","featureId":"PROD_FEAT_16042","order":12000,"name":"Reihe","type":null,"unit":null,"value":"AirPods (4th generation)","valuesAndUnits":[{"__typename":"GraphqlFeatureValue","id":null,"value":"AirPods (4th generation)","unit":null}]},"GraphqlProductFeature:PROD_FEAT_16746:2024-09-20":{"__typename":"GraphqlProductFeature","featureId":"PROD_FEAT_16746","order":5010,"name":"Produkt Einführungsdatum nationaler Markt","type":null,"unit":null,"value":"2024-09-20","valuesAndUnits":[{"__typename":"GraphqlFeatureValue","id":null,"value":"2024-09-20","unit":null}]},"GraphqlProductFeature:PROD_FEAT_16743:Unbekannt":{"__typename":"GraphqlProductFeature","featureId":"PROD_FEAT_16743","order":5020,"name":"Herstellerunterstützte Software Updates","type":null,"unit":null,"value":"Unbekannt","valuesAndUnits":[{"__typename":"GraphqlFeatureValue","id":"2","value":"Unbekannt","unit":null}]},"GraphqlProductFeature:PROD_FEAT_94006:https:\u002F\u002Fregulatoryinfo.apple.com\u002Feudataact":{"__typename":"GraphqlProductFeature","featureId":"PROD_FEAT_94006","order":60300,"name":"Link zu Herstellerinformationen","type":null,"unit":null,"value":"https:\u002F\u002Fregulatoryinfo.apple.com\u002Feudataact","valuesAndUnits":[{"__typename":"GraphqlFeatureValue","id":null,"value":"https:\u002F\u002Fregulatoryinfo.apple.com\u002Feudataact","unit":null}]},"GraphqlProductFeatureGroups:147869562":{"__typename":"GraphqlProductFeatureGroups","productId":"147869562","featureGroups":[{"__typename":"GraphqlProductFeatureGroup","featureGroupId":"FET_GRP_1461_1040","featureGroupName":"Technische Merkmale","features":[{"__ref":"GraphqlProductFeature:PROD_FEAT_10990:Kopfhörer"},{"__ref":"GraphqlProductFeature:PROD_FEAT_12163:iPhone Modelle mit der neuesten iOS Version, iPad M