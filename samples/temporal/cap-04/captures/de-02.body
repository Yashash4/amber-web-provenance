false},"GraphqlReviewer:1751373671":{"__typename":"GraphqlReviewer","id":"1751373671","displayName":"Maria","verifiedBuyer":false},"GraphqlReview:1220646755":{"__typename":"GraphqlReview","id":"1220646755","cid":"42d07ceb-975c-5188-ad41-5011b59b2cb0","contentLocale":"de_DE","date":"2026-05-27T18:07:53.000+00:00","feedbackCount":0,"positiveFeedbackCount":0,"negativeFeedbackCount":0,"rating":4,"title":"APPLE AirPods 4 mit Aktiver Geräuschunterdrückung,","isSyndicated":false,"isVerifiedPurchaser":false,"isProductFamilyReview":false,"reviewProductId":"2954282","syndicationSource":null,"feedback":{"__typename":"GraphqlReviewFeedback","advantages":["die AirPods haben kein Silikon und sitzen daher perfekt in schmalen Ohrk","die Verbindung mit dem iPhone ist schnell und hervorragend","die große Öffnung ohne Silikonaufsatz ermöglicht eine schnelle Reinigung"],"disadvantages":["die Ladecase zieht schnell Dreck und Staub an ","für den Preis ist das Noise Cancelling nicht das beste auf dem Markt","Mancher Dreck aus der Case ist nur bedingt zu lösen"],"full":"Im Großen und Ganzen bin ich sehr zufrieden mit meinen AirPods. Durch meine schmalen Ohrkanäle hatte ich schon immer Probleme mit Silikonaufsätzen in Kopfhörern, da sie nie gehalten haben und aus meinen Ohren rausgefallen sind. Durch den kurzen Steg fallen die Kopfhörer nicht auf und stören nicht bei der Verwendung. Ich nutze sie täglich, sei es auf dem Weg zur Bahn, im Nahverkehr, beim Sport oder beim Staubsaugen zu Hause. Ich bin gerne aktiv und habe meine Kopfhörer gerne beim Laufen, Bouldern oder Handstand üben immer drin - dem haben sie bisher immer Stand gehalten.\nAuch wenn ich den Preis ziemlich hoch für die Qualität des Produkts finde, bin ich sehr zufrieden mit meinem Einkauf. Wer sich für vollständiges Noise-Cancelling interessiert, sollte immer zu Over-Head-Kopfhörern greifen, jedoch bin ich im Hinblick auf meine Nutzung des Produkts sehr zufrieden."},"photos":[],"videos":[],"isIncentivized":false,"reviewer":{"__ref":"GraphqlReviewer:1751373671"},"sourceClient":"mediamarkt","lottery":null,"isRatingsOnly":false},"GraphqlReviewer:hlcmx02qxo2hudr7gctv4m0rc":{"__typename":"GraphqlReviewer","id":"hlcmx02qxo2hudr7gctv4m0rc","displayName":null,"verifiedBuyer":false},"GraphqlReview:1220572841":{"__typename":"GraphqlReview","id":"1220572841","cid":"5c82f165-503e-5743-a8de-cfe2a30295dc","contentLocale":"de_DE","date":"2026-05-26T17:34:27.000+00:00","feedbackCount":0,"positiveFeedbackCount":0,"negativeFeedbackCount":0,"rating":5,"title":"","isSyndicated":false,"isVerifiedPurchaser":true,"isProductFamilyReview":true,"reviewProductId":"3013574","syndicationSource":null,"feedback":{"__typename":"GraphqlReviewFeedback","advantages":[],"disadvantages":[],"full":""},"photos":[],"videos":[],"isIncentivized":false,"reviewer":{"__ref":"GraphqlReviewer:hlcmx02qxo2hudr7gctv4m0rc"},"sourceClient":"mediamarkt","lottery":null,"isRatingsOnly":true},"GraphqlReviewer:dy1n9v3a8qur5o4ca5pyjei42":{"__typename":"GraphqlReviewer","id":"dy1n9v3a8qur5o4ca5pyjei42","displayName":"Moyo","verifiedBuyer":false},"GraphqlReview:1220567509":{"__typename":"GraphqlReview","id":"1220567509","cid":"60786e8d-85f9-5b01-9dc0-83d0c5cd14c5","contentLocale":"de_DE","date":"2026-05-26T16:05:02.000+00:00","feedbackCount":0,"positiveFeedbackCount":0,"negativeFeedbackCount":0,"rating":5,"title":"","isSyndicated":false,"isVerifiedPurchaser":true,"isProductFamilyReview":true,"reviewProductId":"3013574","syndicationSource":null,"feedback":{"__typename":"GraphqlReviewFeedback","advantages":[],"disadvantages":[],"full":""},"photos":[],"videos":[],"isIncentivized":false,"reviewer":{"__ref":"GraphqlReviewer:dy1n9v3a8qur5o4ca5pyjei42"},"sourceClient":"mediamarkt","lottery":null,"isRatingsOnly":true},"GraphqlReviewer:1030432803":{"__typename":"GraphqlReviewer","id":"1030432803","displayName":"Irina","verifiedBuyer":false},"GraphqlReview:1220507110":{"__typename":"GraphqlReview","id":"1220507110","cid":"b2ea8213-baf6-51a9-bfcf-89e86326df53","contentLocale":"de_DE","date":"2026-05-25T19:08:56.000+00:00","feedbackCount":0,"positiveFeedbackCount":0,"negativeFeedbackCount":0,"rating":5,"title":"","isSyndicated":false,"isVerifiedPurchaser":false,"isProductFamilyReview":true,"reviewProductId":"2954343","syndicationSource":null,"feedback":{"__typename":"GraphqlReviewFeedback","advantages":[],"disadvantages":[],"full":""},"photos":[],"videos":[],"isIncentivized":false,"reviewer":{"__ref":"GraphqlReviewer:1030432803"},"sourceClient":"mediamarkt","lottery":null,"isRatingsOnly":true},"GraphqlReviewer:613526972":{"__typename":"GraphqlReviewer","id":"613526972","displayName":"Nils","verifiedBuyer":false},"GraphqlReview:1220497385":{"__typename":"GraphqlReview","id":"1220497385","cid":"04c9c0e0-d496-5345-bb41-d1ab6c35b509","contentLocale":"de_DE","date":"2026-05-25T16:51:31.000+00:00","feedbackCount":0,"positiveFeedbackCount":0,"negativeFeedbackCount":0,"rating":5,"title":"Einmal AirPods Pro immer AirPods Pro","isSyndicated":false,"isVerifiedPurchaser":false,"isProductFamilyReview":true,"reviewProductId":"3013574","syndicationSource":null,"feedback":{"__typename":"GraphqlReviewFeedback","advantages":["Super Klang","Sehr guter Halt","Sehr gutes ANC"],"disadvantages":["Für alle Funktionen sind Apple Geräte notwendig"],"full":"Ich habe mir damals die ersten AirPods Pro gekauft und habe diese nun endgültig in Rente geschickt und durch die AirPods Pro 3 ersetzt. Der Klang ist noch besser, das ANC noch stärker und die Gesprächserkennung bei aktivem ANC macht es unnötig Wiedergaben zu unterbrechen. Ich bin begeistert und werde den AirPods Pro weiterhin treu bleiben. \n\nFür den vollen Funktionsumfang sollte aber jedem bewusst sein, dass Apple Geräte (iPhone, iPad, MacBook) erforderlich sind. Das ist leider teil der Apple Firmenpolitik das Apple Ökosystem zu pushen. Aber die AirPods Pro 3 funktionieren auch mit jedem anderen Wiedergabegerät per Bluetooth einwandfrei."},"photos":[],"videos":[],"isIncentivized":false,"reviewer":{"__ref":"GraphqlReviewer:613526972"},"sourceClient":"mediamarkt","lottery":null,"isRatingsOnly":false},"GraphqlReviewer:6ym7yv4hq7qpzhskywxn6auqy":{"__typename":"GraphqlReviewer","id":"6ym7yv4hq7qpzhskywxn6auqy","displayName":"Kekko","verifiedBuyer":false},"GraphqlReview:1220339584":{"__typename":"GraphqlReview","id":"1220339584","cid":"5ebe4ff8-bd91-5e5e-84e8-c90dbd49e850","contentLocale":"de_DE","date":"2026-05-23T08:09:43.000+00:00","feedbackCount":0,"positiveFeedbackCount":0,"negativeFeedbackCount":0,"rating":5,"title":"","isSyndicated":false,"isVerifiedPurchaser":true,"isProductFamilyReview":true,"reviewProductId":"3013574","syndicationSource":null,"feedback":{"__typename":"GraphqlReviewFeedback","advantages":[],"disadvantages":[],"full":"Klasse produkt-macht Spaß."},"photos":[],"videos":[],"isIncentivized":false,"reviewer":{"__ref":"GraphqlReviewer:6ym7yv4hq7qpzhskywxn6auqy"},"sourceClient":"mediamarkt","lottery":null,"isRatingsOnly":false},"GraphqlMarketplaceOfferV3:1756199700":{"__typename":"GraphqlMarketplaceOfferV3","offerId":1756199700,"productId":"147869562","price":192.47,"currencyIsoCode":"EUR","strikePriceAmount":null,"strikePriceType":null,"sellerId":3285,"sellerName":"Office-Partner","sellerRating":4.64,"deliveryOptions":[{"__typename":"GraphqlMarketplaceOfferDeliveryOptions","costAmount":0,"home":[{"__typename":"GraphqlMarketplaceHomeDeliveryVariant","name":"STANDARD","deliveryDates":[{"__typename":"GraphqlMarketplaceDeliveryDate","earliest":"2026-06-03T20:59:59.999Z","latest":"2026-06-05T20:59:59.999Z","validUntil":null}]}]}],"sellerDetails":{"__typename":"GraphqlMarketplaceSeller","visibleReviewsCount":106},"offerCondition":"NEW","cofrProductAggregate({})":{"__typename":"CofrProductAggregate","cofrCoreFeature":{"__ref":"CofrCoreFeature:Media:de:147869562[1756199700]"},"cofrPriceFeature":{"__ref":"CofrPriceFeature:{\"id\":\"Media:de:147869562[1756199700]\",\"price\":{\"installment\":{\"__typename\":null}}}"},"cofrOnlineStatusFeature":{"__r